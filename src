              {company.name&&<div style={{fontSize:11,color:C.accent,marginTop:8,fontWeight:600}}>📄 Documents branded: {company.name}</div>}
            </div>
            {qp.map((p,i)=>(
              <button key={i} onClick={()=>{setInput(p);send(p);}} style={{padding:"11px 13px",background:C.card,border:`1px solid ${C.border}`,borderRadius:12,textAlign:"left",cursor:"pointer",color:C.textDim,fontSize:13,fontFamily:"inherit",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
