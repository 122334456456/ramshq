      {/* Messages */}
      <div style={{flex:1,overflowY:"auto",padding:"12px 14px 8px"}}>
        {msgs.length===0&&(
          <div style={{display:"flex",flexDirection:"column",gap:10}}>
            <div style={{textAlign:"center",padding:"20px 12px"}}>
              <div style={{fontSize:36,marginBottom:10}}>{mode==="generate"?"⚡":mode==="review"?"🔍":"🎓"}</div>
              <div style={{fontSize:13,fontWeight:700,color:cfg.color,marginBottom:5}}>{cfg.title}</div>
