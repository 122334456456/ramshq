        </div>
      )}

      {/* Input */}
      <div style={{padding:"8px 12px 10px",borderTop:`1px solid ${C.border}`,flexShrink:0}}>
        <div style={{display:"flex",gap:8,alignItems:"flex-end"}}>
          <div style={{flex:1,background:C.card,borderRadius:16,border:`1.5px solid ${input?cfg.color+"66":C.border}`,padding:"9px 12px",transition:"border-color 0.2s"}}>
