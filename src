function ChatScreen({ mode, company, onBack, onDocSaved }) {
  const [msgs,setMsgs]=useState([]);const [input,setInput]=useState("");const [loading,setLoading]=useState(false);
  const [juris,setJuris]=useState("🇬🇧 UK");const [quizData,setQuizData]=useState(null);const [showQuiz,setShowQuiz]=useState(false);const [score,setScore]=useState(null);
  const endRef=useRef(null);
  useEffect(()=>{endRef.current?.scrollIntoView({behavior:"smooth"});},[msgs,loading]);

  const cfg={
    generate:{title:"Generate RAMS",color:C.accent,ph:"Describe the task… e.g. 'Roof repair on 3-storey building, 2 workers'"},
    review:{title:"Review RAMS",color:C.gold,ph:"Paste your existing RAMS document for AI gap analysis…"},
    toolbox:{title:"Toolbox Talk",color:"#A78BFA",ph:"Describe the topic or paste a RAMS to generate a talk + 10-question test…"},
  }[mode];

  const qp={generate:["Roof repair, 2 workers","Electrical install in ceiling void","Excavation near live services"],toolbox:["Working at height briefing","Manual handling induction"],review:[]}[mode]||[];

  const parseQ=text=>{const qs=[];const blocks=text.split(/Q\d+\./g).filter(b=>b.trim());for(const b of blocks){const lines=b.trim().split("\n").filter(l=>l.trim());if(lines.length<4)continue;const question=lines[0].trim();const opts=[];let correct=0,expl="";for(const l of lines.slice(1)){const om=l.match(/^[A-D]\)\s*(.+)/);if(om)opts.push(om[1].trim());const cm=l.match(/CORRECT:\s*([A-D])/i);if(cm){correct="ABCD".indexOf(cm[1].toUpperCase());expl=l.replace(/.*CORRECT:\s*[A-D]\s*[-—]\s*/i,"").trim();}}if(opts.length>=3)qs.push({question,options:opts,correct,explanation:expl});}return qs;};
  const parseScore=text=>{const m=text.match(/Quality Score[:\s]+(\d+)\/100/)||text.match(/(\d+)\/100/);return m?parseInt(m[1]):null;};

  const send=async(ov)=>{
    const msg=(ov||input).trim();if(!msg||loading)return;setInput("");
    const prefix={generate:`MODE: GENERATE RAMS. Jurisdiction: ${juris}.\nTask: `,review:"MODE: REVIEW RAMS:\n",toolbox:"MODE: TOOLBOX TALK + 10-question test for: "}[mode];
    const nm=[...msgs,{role:"user",content:msg}];setMsgs(nm);setLoading(true);
    try{
      const res=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json","x-api-key":import.meta.env.VITE_ANTHROPIC_API_KEY,"anthropic-version":"2023-06-01","anthropic-dangerous-allow-browser":"true"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:3000,system:buildPrompt(company),messages:nm.map((m,i)=>({role:m.role,content:i===nm.length-1&&m.role==="user"?prefix+m.content:m.content}))})});
      const data=await res.json();const reply=data.content?.[0]?.text||"⚠️ No response.";
      setMsgs(prev=>[...prev,{role:"assistant",content:reply}]);
      const sc=parseScore(reply);if(sc)setScore(sc);
      if(mode==="toolbox"){const qs=parseQ(reply);if(qs.length>=5)setQuizData(qs);}
      onDocSaved({type:mode,title:msg.slice(0,40),score:sc});
    }catch{setMsgs(prev=>[...prev,{role:"assistant",content:"⚠️ Connection error."}]);}
    setLoading(false);
  };

  return(
    <div style={{flex:1,display:"flex",flexDirection:"column",minHeight:0,position:"relative"}}>
      {/* Top bar */}
      <div style={{padding:"11px 14px",display:"flex",alignItems:"center",gap:10,borderBottom:`1px solid ${C.border}`,flexShrink:0}}>
        <button onClick={onBack} style={{width:32,height:32,borderRadius:10,background:C.card,border:`1px solid ${C.border}`,display:"flex",alignItems:"center",justifyContent:"center",cursor:"pointer",color:C.textDim,flexShrink:0}}>
          <Ic n="back" s={15}/>
        </button>
        <div style={{flex:1}}>
          <div style={{fontSize:14,fontWeight:800,color:cfg.color}}>{cfg.title}</div>
          {company.name&&<div style={{fontSize:10,color:C.textDim}}>🏢 {company.name}</div>}
        </div>
        {score&&<ScoreRing score={score} size={38}/>}
      </div>

      {/* Company header strip */}
      {company.name&&(
        <div style={{margin:"10px 14px 0",background:`linear-gradient(135deg,${C.navyMid},${C.card})`,borderRadius:12,padding:"10px 12px",border:`1px solid ${C.accent}22`,display:"flex",alignItems:"center",gap:10,flexShrink:0}}>
          {company.logoUrl&&<img src={company.logoUrl} alt="" style={{height:32,width:32,objectFit:"contain",borderRadius:7,background:"#fff",padding:2,flexShrink:0}}/>}
          <div style={{flex:1,minWidth:0}}>
            <div style={{fontSize:12,fontWeight:800,color:C.text,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{company.name}</div>
            <div style={{display:"flex",gap:8}}>
              {company.phone&&<span style={{fontSize:10,color:C.textDim}}>📞 {company.phone}</span>}
              {company.regNumber&&<span style={{fontSize:10,color:C.textFaint}}>Reg: {company.regNumber}</span>}
            </div>
          </div>
          {company.sector&&<span style={{fontSize:10,color:C.accent,fontWeight:700,background:`${C.accent}15`,padding:"2px 8px",borderRadius:20,flexShrink:0}}>{company.sector}</span>}
        </div>
      )}

      {/* Jurisdiction */}
      {mode==="generate"&&(
        <div style={{padding:"10px 14px 0",display:"flex",gap:6,overflowX:"auto",flexShrink:0}}>
          {["🇬🇧 UK","🇪🇺 EU","🇦🇪 UAE","🇺🇸 US"].map(j=>(
            <button key={j} onClick={()=>setJuris(j)} style={{padding:"5px 12px",borderRadius:20,border:`1px solid ${juris===j?C.accent:C.border}`,background:juris===j?`${C.accent}22`:"transparent",color:juris===j?C.accent:C.textDim,fontSize:11,fontWeight:700,cursor:"pointer",fontFamily:"inherit",whiteSpace:"nowrap"}}>{j}</button>
          ))}
        </div>
