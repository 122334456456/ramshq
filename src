function ScoreBar({label,score,max,color}) {
  return (
    <div style={{marginBottom:10}}>
      <div style={{display:"flex",justifyContent:"space-between",marginBottom:3}}>
        <span style={{fontSize:12,color:B.text}}>{label}</span>
        <span style={{fontSize:12,fontWeight:700,color}}>{score}/{max}</span>
      </div>
      <div style={{height:7,background:"#E2E8F0",borderRadius:4,overflow:"hidden"}}>
        <div style={{height:"100%",width:`${Math.round((score/max)*100)}%`,background:color,borderRadius:4,transition:"width 1s ease"}} />
      </div>
    </div>
  );
}

function QuizMode({questions,onClose}) {
  const [cur,setCur]=useState(0);const [sel,setSel]=useState(null);const [ans,setAns]=useState([]);const [done,setDone]=useState(false);
  const q=questions[cur]; const score=ans.filter(a=>a.correct).length;
  const next=()=>{const na=[...ans,{correct:sel===q.correct}];setAns(na);if(cur+1>=questions.length)setDone(true);else{setCur(c=>c+1);setSel(null);}};
  if(done){const pass=score>=Math.ceil(questions.length*0.8);return(
    <div style={{textAlign:"center",padding:28}}>
      <div style={{fontSize:52,marginBottom:10}}>{pass?"🏆":"📚"}</div>
      <h2 style={{fontSize:22,color:pass?B.accent:B.danger,marginBottom:6}}>{pass?"PASSED!":"RE-BRIEFING REQUIRED"}</h2>
      <p style={{fontSize:16,marginBottom:16}}>Score: {score}/{questions.length} ({Math.round((score/questions.length)*100)}%)</p>
      <p style={{color:B.muted,marginBottom:20,fontSize:13}}>{pass?"Worker cleared to proceed.":"Must be re-briefed before starting work."}</p>
      <div style={{display:"flex",gap:10,justifyContent:"center"}}>
        <button onClick={()=>{setCur(0);setSel(null);setAns([]);setDone(false);}} style={{padding:"9px 20px",background:B.primary,color:"#fff",border:"none",borderRadius:8,cursor:"pointer",fontWeight:700,fontFamily:"inherit"}}>Retake</button>
        <button onClick={onClose} style={{padding:"9px 20px",background:"#E2E8F0",color:B.text,border:"none",borderRadius:8,cursor:"pointer",fontWeight:700,fontFamily:"inherit"}}>Close</button>
      </div>
    </div>
  );}
  return(
    <div style={{padding:22}}>
      <div style={{display:"flex",alignItems:"center",marginBottom:14,gap:10}}>
        <span style={{fontSize:12,color:B.muted,flexShrink:0}}>Q{cur+1}/{questions.length}</span>
        <div style={{flex:1,height:5,background:"#E2E8F0",borderRadius:3}}><div style={{height:"100%",width:`${(cur/questions.length)*100}%`,background:B.accent,borderRadius:3}}/></div>
        <span style={{fontSize:12,color:B.accent,fontWeight:700,flexShrink:0}}>{score} ✓</span>
      </div>
      <h3 style={{fontSize:15,marginBottom:14,lineHeight:1.6}}>{q.question}</h3>
      <div style={{display:"flex",flexDirection:"column",gap:8}}>
        {q.options.map((opt,idx)=>{
          let bg="#F7FAFC",border="#E2E8F0",col=B.text;
          if(sel!==null){if(idx===q.correct){bg="#C6F6D5";border=B.accent;col="#276749";}else if(idx===sel){bg="#FED7D7";border=B.danger;col="#9B2C2C";}}
          return(<button key={idx} onClick={()=>sel===null&&setSel(idx)} style={{padding:"11px 13px",background:bg,border:`2px solid ${border}`,borderRadius:8,cursor:sel!==null?"default":"pointer",textAlign:"left",color:col,fontFamily:"inherit",fontSize:13,transition:"all 0.2s"}}>
            <span style={{fontWeight:700,marginRight:7}}>{["A","B","C","D"][idx]}.</span>{opt}
          </button>);
        })}
      </div>
      {sel!==null&&<div style={{marginTop:12,padding:11,background:sel===q.correct?"#F0FFF4":"#FFF5F5",borderRadius:8,borderLeft:`4px solid ${sel===q.correct?B.accent:B.danger}`}}><p style={{fontSize:12,margin:0}}><strong>{sel===q.correct?"✅ Correct!":"❌ Incorrect."}</strong> {q.explanation}</p></div>}
      {sel!==null&&<button onClick={next} style={{marginTop:12,width:"100%",padding:"11px",background:B.primary,color:"#fff",border:"none",borderRadius:8,cursor:"pointer",fontWeight:700,fontSize:14,fontFamily:"inherit"}}>{cur+1>=questions.length?"See Results":"Next →"}</button>}
    </div>
  );
}

const TABS=[{id:"generate",label:"⚡ Generate RAMS"},{id:"review",label:"📋 Review RAMS"},{id:"toolbox",label:"🎓 Toolbox Talk"}];
const JURIS=["🇬🇧 UK (HSE)","🇪🇺 EU Directives","🇦🇪 UAE (OSHAD)","🇺🇸 US (OSHA)"];
const EMPTY={name:"",address:"",phone:"",email:"",website:"",regNumber:"",vatNumber:"",insuranceRef:"",hseNumber:"",hsContact:"",hsPhone:"",sector:"",logoUrl:null};

export default function RAMSHQApp() {
  const [tab,setTab]=useState("generate");
  const [input,setInput]=useState("");
  const [msgs,setMsgs]=useState([]);
  const [loading,setLoading]=useState(false);
  const [juris,setJuris]=useState(JURIS[0]);
  const [quizData,setQuizData]=useState(null);
  const [showQuiz,setShowQuiz]=useState(false);
  const [scoreData,setScoreData]=useState(null);
  const [showModal,setShowModal]=useState(false);
  const [co,setCo]=useState(EMPTY);
  const endRef=useRef(null);

  useEffect(()=>{endRef.current?.scrollIntoView({behavior:"smooth"});},[msgs,loading]);

  const parseQ=text=>{
    const qs=[];const blocks=text.split(/Q\d+\./g).filter(b=>b.trim());
    for(const b of blocks){const lines=b.trim().split("\n").filter(l=>l.trim());if(lines.length<4)continue;
      const question=lines[0].trim();const opts=[];let correct=0,expl="";
      for(const l of lines.slice(1)){const om=l.match(/^[A-D]\)\s*(.+)/);if(om)opts.push(om[1].trim());const cm=l.match(/CORRECT:\s*([A-D])/i);if(cm){correct="ABCD".indexOf(cm[1].toUpperCase());expl=l.replace(/.*CORRECT:\s*[A-D]\s*[-—]\s*/i,"").trim();}}
      if(opts.length>=3)qs.push({question,options:opts,correct,explanation:expl});}
    return qs;
  };

  const parseSc=text=>{
    const sc={};
    const patterns=[
      {key:"hazard",label:"Hazard ID",max:25,regex:/Hazard Identification.*?(\d+)/i},
      {key:"risk",label:"Risk Rating",max:20,regex:/Risk Rating.*?(\d+)/i},
      {key:"control",label:"Controls",max:20,regex:/Control Measures.*?(\d+)/i},
      {key:"ppe",label:"PPE Quality",max:15,regex:/PPE.*?(\d+)/i},
      {key:"method",label:"Method Statement",max:10,regex:/Method Statement.*?(\d+)/i},
      {key:"legal",label:"Legal Refs",max:10,regex:/Legal.*?(\d+)/i},
    ];
    for(const p of patterns){const m=text.match(p.regex);if(m)sc[p.key]={...p,score:Math.min(parseInt(m[1]),p.max)};}
    const tm=text.match(/Overall.*?(\d+)\/100/i)||text.match(/(\d+)\/100/);if(tm)sc.total=parseInt(tm[1]);
    return Object.keys(sc).length>1?sc:null;
  };

  const send=async()=>{
    if(!input.trim()||loading)return;
    const msg=input.trim();setInput("");
    const prefix=tab==="review"?"MODE 1 — Review this RAMS:\n\n":tab==="generate"?`MODE 2 — Generate RAMS. Jurisdiction: ${juris}:\n\n`:"MODE 3 — Toolbox Talk + 10-question test for: ";
    const newMsgs=[...msgs,{role:"user",content:msg}];
    setMsgs(newMsgs);setLoading(true);
    try{
      const res=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json","x-api-key":import.meta.env.VITE_ANTHROPIC_API_KEY,"anthropic-version":"2023-06-01","anthropic-dangerous-allow-browser":"true"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:4000,system:buildPrompt(co),messages:newMsgs.map((m,i)=>({role:m.role,content:i===newMsgs.length-1&&m.role==="user"?prefix+m.content:m.content}))})});
      const data=await res.json();const reply=data.content?.[0]?.text||"⚠️ No response.";
      setMsgs(prev=>[...prev,{role:"assistant",content:reply}]);
      if(tab==="toolbox"){const qs=parseQ(reply);if(qs.length>=5)setQuizData(qs);}
      const sc=parseSc(reply);if(sc)setScoreData(sc);
    }catch{setMsgs(prev=>[...prev,{role:"assistant",content:"⚠️ Connection error."}]);}
    setLoading(false);
  };

  const ph={generate:"Describe the task in plain English. E.g: 'Installing electrical cabling in a commercial building, 4 electricians on site'",review:"Paste your existing RAMS document here for AI gap analysis against IOSH & NEBOSH standards...",toolbox:"Enter a task or paste a RAMS to generate a toolbox talk + interactive 10-question quiz..."};
  const ex={generate:["Roof repair on 3-storey building, 2 workers","Excavation works near live services","Install heavy plant machinery in factory"],toolbox:["Working at height safety briefing","Manual handling induction","Electrical safety toolbox talk"],review:[]};

  return(
    <div style={{fontFamily:"'Segoe UI',system-ui,sans-serif",background:B.light,minHeight:"100vh"}}>
      <style>{`@keyframes bounce{0%,80%,100%{transform:translateY(0)}40%{transform:translateY(-7px)}} @keyframes fadeIn{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:translateY(0)}} .msg{animation:fadeIn 0.3s ease} textarea:focus{outline:none!important;border-color:#00C896!important} ::-webkit-scrollbar{width:5px} ::-webkit-scrollbar-thumb{background:#CBD5E0;border-radius:3px} button{font-family:inherit}`}</style>

      {/* ── HEADER ── */}
      <div style={{background:B.primary,padding:"0 20px",position:"sticky",top:0,zIndex:100,boxShadow:"0 2px 12px rgba(0,0,0,0.18)"}}>
        <div style={{maxWidth:1100,margin:"0 auto",display:"flex",alignItems:"center",justifyContent:"space-between",height:62}}>
          <div style={{display:"flex",alignItems:"center",gap:11}}>
