function Spinner() {
  return <div style={{ display: "flex", gap: 5, padding: "6px 0" }}>{[0,1,2].map(i=><div key={i} style={{ width: 7, height: 7, borderRadius: "50%", background: C.accent, animation: "rp 1.2s ease-in-out infinite", animationDelay: `${i*0.18}s` }}/>)}</div>;
}

function ScoreRing({ score, size=70 }) {
  const r = size/2-5; const circ = 2*Math.PI*r;
  const color = score>=80?C.accent:score>=60?C.warning:C.danger;
  return (
    <div style={{ position:"relative", width:size, height:size, flexShrink:0 }}>
      <svg width={size} height={size} style={{ transform:"rotate(-90deg)" }}>
        <circle cx={size/2} cy={size/2} r={r} fill="none" stroke={C.border} strokeWidth="5"/>
        <circle cx={size/2} cy={size/2} r={r} fill="none" stroke={color} strokeWidth="5" strokeDasharray={circ} strokeDashoffset={circ*(1-score/100)} strokeLinecap="round" style={{ transition:"stroke-dashoffset 1s ease" }}/>
      </svg>
      <div style={{ position:"absolute", inset:0, display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center" }}>
        <span style={{ fontSize:size*0.22, fontWeight:900, color, lineHeight:1 }}>{score}</span>
        <span style={{ fontSize:size*0.13, color:C.textDim }}>/ 100</span>
      </div>
    </div>
  );
}

function QuizScreen({ questions, onClose }) {
  const [idx,setIdx]=useState(0);const [picked,setPicked]=useState(null);const [ans,setAns]=useState([]);const [done,setDone]=useState(false);
  const q=questions[idx]; const score=ans.filter(Boolean).length;
  const pick=i=>{if(picked!==null)return;setPicked(i);};
  const next=()=>{const na=[...ans,picked===q.correct];setAns(na);if(idx+1>=questions.length)setDone(true);else{setIdx(i=>i+1);setPicked(null);}};
  if(done){const pass=score>=Math.ceil(questions.length*0.8);return(
    <div style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:24,gap:16}}>
      <div style={{fontSize:60}}>{pass?"🏆":"📚"}</div>
      <div style={{fontSize:24,fontWeight:900,color:pass?C.accent:C.danger,textAlign:"center"}}>{pass?"Test Passed!":"Re-brief Required"}</div>
      <ScoreRing score={Math.round((score/questions.length)*100)} size={90}/>
      <div style={{textAlign:"center",color:C.textDim,fontSize:13,lineHeight:1.6}}>{score}/{questions.length} correct · Pass mark 80%<br/>{pass?"Worker cleared to proceed.":"Must be re-briefed before starting."}</div>
      <button onClick={()=>{setIdx(0);setPicked(null);setAns([]);setDone(false);}} style={{width:"100%",padding:"13px",background:C.card,border:`1px solid ${C.border}`,borderRadius:12,color:C.text,fontSize:14,fontWeight:700,cursor:"pointer",fontFamily:"inherit"}}>Retake</button>
      <button onClick={onClose} style={{width:"100%",padding:"13px",background:C.accent,border:"none",borderRadius:12,color:"#001a12",fontSize:14,fontWeight:900,cursor:"pointer",fontFamily:"inherit"}}>Done ✓</button>
    </div>
  );}
  return(
    <div style={{flex:1,display:"flex",flexDirection:"column",padding:"14px 18px",gap:14,overflowY:"auto"}}>
      <div style={{display:"flex",gap:3}}>{questions.map((_,i)=><div key={i} style={{flex:1,height:3,borderRadius:2,background:i<idx?C.accent:i===idx?`${C.accent}77`:C.border,transition:"background 0.3s"}}/>)}</div>
      <div style={{fontSize:11,color:C.textDim}}>Q{idx+1} of {questions.length} · {score} correct</div>
      <div style={{background:C.card,borderRadius:14,padding:16,border:`1px solid ${C.border}`,fontSize:14,fontWeight:600,lineHeight:1.6}}>{q.question}</div>
      <div style={{display:"flex",flexDirection:"column",gap:9}}>
        {q.options.map((opt,i)=>{
          const isC=i===q.correct,isP=i===picked;
          let bg=C.card,border=C.border,col=C.text;
          if(picked!==null){if(isC){bg="#003d2e";border=C.accent;col=C.accent;}else if(isP){bg="#3d0000";border=C.danger;col=C.danger;}}
          return(<button key={i} onClick={()=>pick(i)} style={{padding:"12px 14px",background:bg,border:`1.5px solid ${border}`,borderRadius:12,textAlign:"left",cursor:picked!==null?"default":"pointer",color:col,fontSize:13,fontFamily:"inherit",transition:"all 0.2s",display:"flex",gap:10,alignItems:"center"}}>
            <span style={{width:26,height:26,borderRadius:"50%",border:`1.5px solid ${border}`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:11,fontWeight:900,flexShrink:0}}>{["A","B","C","D"][i]}</span>
            <span style={{flex:1}}>{opt}</span>
            {picked!==null&&isC&&<Ic n="check" s={15} c={C.accent}/>}
          </button>);
        })}
      </div>
      {picked!==null&&<div style={{background:picked===q.correct?"#002d22":"#2d0000",border:`1px solid ${picked===q.correct?C.accent:C.danger}22`,borderRadius:10,padding:12,fontSize:12,color:C.textDim,lineHeight:1.6}}><strong style={{color:picked===q.correct?C.accent:C.danger}}>{picked===q.correct?"✓ Correct — ":"✗ Incorrect — "}</strong>{q.explanation}</div>}
      {picked!==null&&<button onClick={next} style={{padding:"14px",background:C.accent,border:"none",borderRadius:12,color:"#001a12",fontSize:15,fontWeight:900,cursor:"pointer",fontFamily:"inherit",marginTop:"auto"}}>{idx+1>=questions.length?"See Results":"Next →"}</button>}
    </div>
  );
}

